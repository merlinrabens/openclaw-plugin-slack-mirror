{
  "name": "@bluedigits/openclaw-plugin-slack-mirror",
  "version": "0.1.0",
  "description": "OpenClaw plugin: invisible Slack mirror — mirrors your Slack identity (no bot user), forwards @mentions to any channel (Telegram/WhatsApp/Discord), and posts AS YOU on command. Uses browser session tokens (xoxc/xoxd) for listening; supports xoxp user OAuth for posting.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "Merlin Rabens <bluedigits@gmail.com>",
  "homepage": "https://github.com/merlinrabens/openclaw-plugin-slack-mirror",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merlinrabens/openclaw-plugin-slack-mirror.git"
  },
  "bugs": {
    "url": "https://github.com/merlinrabens/openclaw-plugin-slack-mirror/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "slack",
    "mirror",
    "user-impersonation",
    "telegram",
    "whatsapp",
    "channel-bridge",
    "notifications",
    "xoxc",
    "browser-session"
  ],
  "bin": {
    "slack-mirror-cli": "./dist/bin/cli.js"
  },
  "files": [
    "dist/**/*",
    "openclaw.plugin.json",
    "browser-extension/**/*",
    "docs/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
